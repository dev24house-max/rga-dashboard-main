# ============================================
# Database (Supabase PostgreSQL)
# ============================================
# Get these from: Supabase Dashboard > Project Settings > Database
# Connection Pooling (recommended for production)
# ใช้ Session Pooler สำหรับทั้ง DATABASE_URL และ DIRECT_URL
# Port 5432 = Session mode (รองรับทั้งหมด)
# Port 6543 = Transaction mode (ไม่รองรับ migrations)

# DATABASE_URL="postgresql://postgres:iSjPjSQZGQx6Qdxy@db.lbyodfrbdwtbezyyilhu.supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres:iSjPjSQZGQx6Qdxy@db.lbyodfrbdwtbezyyilhu.supabase.co:5432/postgres"
DATABASE_URL="postgresql://postgres.lbyodfrbdwtbezyyilhu:iSjPjSQZGQx6Qdxy@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?pgbouncer=true&connect_timeout=30"
DIRECT_URL="postgresql://postgres.lbyodfrbdwtbezyyilhu:iSjPjSQZGQx6Qdxy@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?connect_timeout=30"


# ============================================
# Security
# ============================================
# Encryption key for access tokens (32 bytes hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="a3f8c2d1e4b7f0a1c3e5d2b4f6a8c0e2d4f6a8b0c2e4d6f8a0b2c4e6d8f0a2b4"

# JWT
JWT_SECRET="b5d7f9a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7"
JWT_REFRESH_SECRET="c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Environment
NODE_ENV="production"
PORT=3000

# CORS - Allowed frontend origins
CORS_ORIGINS="https://saddlebrown-eagle-972006.hostingersite.com,http://localhost"

# Frontend URL (Vite default port is 5173)
FRONTEND_URL="https://saddlebrown-eagle-972006.hostingersite.com"

# Google OAuth
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Redirect URIs
GOOGLE_REDIRECT_URI_ADS="https://saddlebrown-eagle-972006.hostingersite.com/auth/google/ads/callback"
GOOGLE_REDIRECT_URI_GA4="https://saddlebrown-eagle-972006.hostingersite.com/auth/google/analytics/callback"

# Google Ads API (Using the same Client ID/Secret)
GOOGLE_ADS_DEVELOPER_TOKEN="YOUR_GOOGLE_ADS_DEVELOPER_TOKEN"
GOOGLE_ADS_LOGIN_CUSTOMER_ID="YOUR_GOOGLE_ADS_LOGIN_CUSTOMER_ID"
GOOGLE_ADS_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_ADS_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# GA4 (Using the same Client ID/Secret)
GA4_PROPERTY_ID="YOUR_GA4_PROPERTY_ID"
GOOGLE_APPLICATION_CREDENTIALS="./ga4-credentials.json"

# ============================================
# Facebook Ads API
# ============================================
# 1. Go to https://developers.facebook.com/
# 2. Create a new app or use existing one
# 3. Add "Marketing API" product to your app
# 4. In App Settings > Basic, copy App ID and App Secret
# 5. In Facebook Login > Settings, add Valid OAuth Redirect URIs
# 6. Make sure your app is in "Live" mode for production
# 7. Request approval for ads_management, ads_read, read_insights permissions

FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"
FACEBOOK_REDIRECT_URI="https://saddlebrown-eagle-972006.hostingersite.com/auth/facebook/ads/callback"

# TikTok Ads API
TIKTOK_APP_ID="YOUR_TIKTOK_APP_ID"
TIKTOK_APP_SECRET="YOUR_TIKTOK_APP_SECRET"
TIKTOK_REDIRECT_URI="https://saddlebrown-eagle-972006.hostingersite.com/auth/tiktok/callback"
TIKTOK_USE_SANDBOX=false
TIKTOK_SANDBOX_ACCESS_TOKEN="YOUR_TIKTOK_SANDBOX_ACCESS_TOKEN"
TIKTOK_SANDBOX_ADVERTISER_ID="YOUR_TIKTOK_SANDBOX_ADVERTISER_ID"

# LINE Ads API (Using LINE Login for OAuth, Mock Data for Ads)
LINE_CHANNEL_ID="YOUR_LINE_CHANNEL_ID"
LINE_CHANNEL_SECRET="YOUR_LINE_CHANNEL_SECRET"
LINE_CALLBACK_URL="https://saddlebrown-eagle-972006.hostingersite.com/auth/line/callback"

# Seed Configuration
SEED_DEMO_DATA=true

# ============================================
# Email Verification (SMTP - Gmail)
# ============================================
# URL used to generate the email verification link that points to the frontend
APP_URL="https://saddlebrown-eagle-972006.hostingersite.com"

# Gmail SMTP (use Google App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="YOUR_SMTP_USER"
SMTP_PASSWORD="YOUR_SMTP_PASSWORD"
EMAIL_FROM="noreply@rga.dashboard.com"


